# =============================================================================
# Core Concepts AI — Environment Template
# =============================================================================
# Copy this file to `.env` and fill in the values for your Supabase project.
#   cp .env.template .env
#
# NOTE: Only the VITE_* variables below are read by the frontend at build time.
# Edge function secrets (GOOGLE_API_KEY, LOVABLE_API_KEY, etc.) are NOT set
# here — they live in Supabase Edge Function secrets. See README §
# "Pre-Build Checklist" for how to set them.
# =============================================================================


# -----------------------------------------------------------------------------
# Frontend — Supabase (REQUIRED)
# -----------------------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
#
# ⚠️  The Supabase client in `src/integrations/supabase/client.ts` ALSO
#     hardcodes the URL and anon key. If you point at a different Supabase
#     project, update both this file AND that client file.

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"


# =============================================================================
# Edge Function Secrets — DO NOT put these in .env
# =============================================================================
# The variables below are listed for reference only. Set them in Supabase:
#
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# or via CLI:
#
#   supabase secrets set GOOGLE_API_KEY="..."
#   supabase secrets set LOVABLE_API_KEY="..."
#
# Required (manual):
#   GOOGLE_API_KEY              Google Cloud key with Text-to-Speech API enabled
#   LOVABLE_API_KEY             Lovable AI Gateway key (or swap to your own LLM)
#
# Auto-injected by Supabase (do not set):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY   ⚠️  Never expose to the frontend
#   SUPABASE_DB_URL
#   SUPABASE_PUBLISHABLE_KEY
# =============================================================================
